# Configuração local com credenciais reais — cada ambiente tem a sua
config/database.php

# Arquivos enviados pelos usuários (fotos e documentos)
public/uploads/fotos/*
public/uploads/documentos/*
!public/uploads/fotos/.gitkeep
!public/uploads/documentos/.gitkeep

# Backups automáticos gerados pelo importador GEDCOM (contêm dados pessoais da família)
backups/*
!backups/.gitkeep

# Arquivos GEDCOM que você for importar (dados pessoais, não devem ir pro repositório)
*.ged

# Diversos
.DS_Store
*.log
